#, c-format
msgid ""
"Could not get photometric from '%s'. Image is CCITT compressed, assuming min-"
"is-white"
msgstr ""
"Ne eblis ricevi fotometrikon de '%s'. Bildo estas CCITT kunpremita, "
"supozante min-estas-blanka"

#: plug-ins/file-tiff/file-tiff-load.c:768
#, c-format
