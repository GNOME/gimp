#: plug-ins/file-tiff/file-tiff-export.c:651
msgid ""
"Only monochrome pictures can be compressed with \"CCITT Group 4\" or \"CCITT "
"Group 3\"."
msgstr ""
"Kompresiou „CCITT Group 4“ alebo „CCITT Group 3“ je možné komprimovať iba "
"monochromatické obrázky."

#: plug-ins/file-tiff/file-tiff-export.c:665
msgid "Indexed pictures cannot be compressed with \"JPEG\"."
msgstr "Indexované obrázky sa nedajú komprimovať pomocou „JPEG“."

#: plug-ins/file-tiff/file-tiff-export.c:724
msgid ""
"The TIFF format only supports comments in\n"
"7bit ASCII encoding. No comment is saved."
msgstr ""
"Formát TIFF podporuje komentáre iba v\n"
"7-bitovom kódovaní ASCII. Žiadny komentár sa neuloží."

#: plug-ins/file-tiff/file-tiff-export.c:866
#, c-format
msgid "Failed a scanline write on row %d"
msgstr "Nepodaril sa zápis scanline na riadku %d"

#: plug-ins/file-tiff/file-tiff-export.c:1202
#, c-format
msgid "Writing pages with different bit depth is strange."
msgstr "Zápis strán s rôznou bitovou hĺbkou je neobvyklý."

#: plug-ins/file-tiff/file-tiff-export.c:1277
msgid ""
"Warning: maximum TIFF file size exceeded. Retry as BigTIFF or with a "
"different compression algorithm, or cancel."
msgstr ""
"Upozornenie: prekročená maximálna veľkosť súboru TIFF. Skúste to znova ako "
"BigTIFF alebo s iným algoritmom kompresie, prípadne akciu zrušte."

#: plug-ins/file-tiff/file-tiff-export.c:1336
#, c-format
msgid ""
"The assigned soft-proofing profile is not a CMYK profile.\n"
"This profile will not be included in the exported image."
msgstr ""
"Priradený profil pre náhľad tlačového výstupu nie je profil CMYK.\n"
"Tento profil nebude zahrnutý v exportovanom obrázku."

#: plug-ins/file-tiff/file-tiff-load.c:312
#, c-format
msgid "Not a TIFF image or image is corrupt."
msgstr "To nie je obrázok TIFF alebo je obrázok poškodený."

#: plug-ins/file-tiff/file-tiff-load.c:339
#, c-format
msgid "TIFF '%s' does not contain any directories"
msgstr "TIFF „%s” neobsahuje žiadne adresáre"

#: plug-ins/file-tiff/file-tiff-load.c:346
#, c-format
msgid ""
"TIFF '%s' directory count by header failed though there seems to be %d page. "
"Attempting to load the file with this assumption."
msgid_plural ""
"TIFF '%s' directory count by header failed though there seem to be %d pages. "
"Attempting to load the file with this assumption."
msgstr[0] ""
"Počítanie adresárov súboru TIFF „%s” podľa údajov hlavičky zlyhalo, hoci sa "
"zdá, že je tam %d strán. Pokúša sa načítať súbor s týmto predpokladom."
msgstr[1] ""
"Počítanie adresárov súboru TIFF „%s” podľa údajov hlavičky zlyhalo, hoci sa "
"zdá, že je tam %d strana. Pokúša sa načítať súbor s týmto predpokladom."
msgstr[2] ""
"Počítanie adresárov súboru TIFF „%s” podľa údajov hlavičky zlyhalo, hoci sa "
"zdá, že sú tam %d strany. Pokúša sa načítať súbor s týmto predpokladom."

#: plug-ins/file-tiff/file-tiff-load.c:477
msgid "Extra channels with unspecified data."
msgstr "Ďalšie kanály s nešpecifikovanými dátami."

#. ExtraSamples field not set, yet we have more channels than
#. * the PhotometricInterpretation field suggests.
#. * This should not happen as the spec clearly says "This field
#. * must be present if there are extra samples". So the files
#. * can be considered non-conformant.
#. * Let's ask what to do with the channel.
#.
#: plug-ins/file-tiff/file-tiff-load.c:489
msgid "Non-conformant TIFF: extra channels without 'ExtraSamples' field."
msgstr "Nekonformný TIFF: nadbytočné kanály bez poľa „ExtraSamples”."

#: plug-ins/file-tiff/file-tiff-load.c:586
#, c-format
msgid "Couldn't read page %d of %d. Image might be corrupt.\n"
msgstr "Nepodarilo sa načítať stranu %d z %d. Obrázok môže byť poškodený.\n"

#: plug-ins/file-tiff/file-tiff-load.c:615
#, c-format
msgid ""
"This image has a linear color profile but it was not set on the first layer. "
"The layers below layer # %d will be interpreted as non linear."
msgstr ""
"Tento obrázok má lineárny farebný profil, ale nebol nastavený na prvej "
"vrstve. Vrstvy pod vrstvou č. %d budú interpretované ako nelineárne."

#: plug-ins/file-tiff/file-tiff-load.c:623
msgid ""
"This image has multiple color profiles. We will use the first one. If this "
"leads to incorrect results you should consider loading each layer as a "
"separate image."
msgstr ""
"Tento obrázok má viaceré farebné profily. Použijeme prvý. Ak to vedie k "
"nesprávnym výsledkom, mali by ste porozmýšľať nad načítaním každej vrstvy "
"ako samostatného obrázka."

#: plug-ins/file-tiff/file-tiff-load.c:635
#, c-format
msgid "Suspicious bit depth: %d for page %d. Image may be corrupt."
msgstr "Podozrivá bitová hĺbka: %d pre stranu %d. Obrázok môže byť poškodený."

#: plug-ins/file-tiff/file-tiff-load.c:709
#, c-format
msgid "Unsupported bit depth: %d for page %d."
msgstr "Nepodporovaná bitová hĺbka: %d pre stranu %d."

#: plug-ins/file-tiff/file-tiff-load.c:724
#, c-format
msgid "Could not get image width from '%s'"
msgstr "Nepodarilo sa získať šírku obrázka z „%s”"

#: plug-ins/file-tiff/file-tiff-load.c:732
#, c-format
msgid "Could not get image length from '%s'"
msgstr "Nepodarilo sa získať dĺžku obrázka z „%s”"

#: plug-ins/file-tiff/file-tiff-load.c:740
#, c-format
msgid "Invalid image dimensions (%u x %u) for page %d. Image may be corrupt."
msgstr ""
"Neplatné rozmery obrázka (%u x %u) pre stranu %d. Obrázok môže byť poškodený."

#: plug-ins/file-tiff/file-tiff-load.c:761
#, c-format
msgid ""
"Could not get photometric from '%s'. Image is CCITT compressed, assuming min-"
"is-white"
msgstr ""
"Nepodarilo sa získať fotometriu z „%s”. Obrázok je komprimovaný metódou "
"CCITT, predpokladá sa, že min-je-biela"

#: plug-ins/file-tiff/file-tiff-load.c:768
#, c-format
msgid "Could not get photometric from '%s'. Assuming min-is-black"
msgstr ""
"Nepodarilo sa získať fotometriu z „%s”. Predpokladá sa, že min-je-čierna"

#. In non-interactive mode, we assume unassociated alpha if unspecified.
#. * We don't output messages in interactive mode as the user
#. * has already the ability to choose through a dialog.
#: plug-ins/file-tiff/file-tiff-load.c:800
#, c-format
msgid ""
"Alpha channel type not defined for %s. Assuming alpha is not premultiplied"
msgstr ""
"Typ alfa kanála nie je definovaný pre %s. Predpokladá sa, že alfa nie je "
"predmnožená"

#: plug-ins/file-tiff/file-tiff-load.c:825
#, c-format
msgid ""
"Image '%s' does not conform to the TIFF specification: ExtraSamples field is "
"not set while extra channels are present. Assuming the first extra channel "
"is non-premultiplied alpha."
msgstr ""
"Obrázok „%s” nie je v súlade so špecifikáciou TIFF: pole ExtraSamples nie je "
"nastavené, pričom sú prítomné ďalšie kanály. Predpokladá sa, že ďalší kanál "
"je alfa kanál."

#: plug-ins/file-tiff/file-tiff-load.c:1114
#, c-format
msgid "Invalid or unknown compression %u. Setting compression to none."
msgstr "Neplatná alebo neznáma kompresia %u. Kompresia sa nastavuje na žiadnu."

#: plug-ins/file-tiff/file-tiff-load.c:1172
#, c-format
msgid "Could not create a new image: %s"
msgstr "Nepodarilo sa vytvoriť nový obrázok: %s"

#: plug-ins/file-tiff/file-tiff-load.c:1359
#, c-format
msgid "Unknown resolution unit type %d, assuming dpi"
msgstr "Neznámy typ jednotky rozlíšenia %d, predpokladá sa dpi"

