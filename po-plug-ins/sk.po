msgstr ""
"Nedá sa exportovať „%s”. Formát súboru GIF nepodporuje obrázky, ktoré sú "
"viac ako %d pixelov široké alebo vysoké."

#: plug-ins/common/file-gif-export.c:691
#, c-format
msgid ""
"Unable to export '%s'.  Please convert your image to 8 bit integer "
"precision, as the GIF file format does not support higher precisions."
msgstr ""
"Nedá sa exportovať „%s”. Konvertujte obrázok na presnosť 8-bitového celého "
"čísla, pretože formát GIF nepodporuje obrázky s vyššou presnosťou."

#: plug-ins/common/file-gif-export.c:820
msgid ""
"The GIF format only supports comments in 7bit ASCII encoding. No comment is "
"saved."
msgstr ""
"Formát GIF podporuje komentáre iba v 7-bitovom kódovaní ASCII. Žiadny "
"komentár sa neuloží."

#
#: plug-ins/common/file-gif-export.c:916
msgid ""
"Cannot export RGB color images. Convert to indexed color or grayscale first."
msgstr ""
"Nedajú sa exportovať farebné obrázky RGB. Najprv preveďte na indexovanú "
"farbu alebo odtiene šedi."

#
#: plug-ins/common/file-gif-export.c:1136
msgid "Delay inserted to prevent evil CPU-sucking animation."
msgstr "Aby sa zabránilo zlej animácii žerúcej CPU, vloží sa omeškanie."

