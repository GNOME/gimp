#: plug-ins/file-tiff/file-tiff-load.c:1469
msgid ""
"Indexed TIFFs with color maps larger than 256colors are not yet supported"
msgstr "Indexované TIFF súbory s farebnými mapami väčšími ako 256 farieb zatiaľ nie sú podporované"

#. Validate number of channels to the same maximum as we use for
