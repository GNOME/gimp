msgstr "Konvertovať do odtieňov sivej"

#: libgimp/gimpexportoptions.c:446
#, c-format
msgid "%s plug-in can only handle indexed images"
msgstr "Zásuvný modul pre %s vie pracovať iba s indexovanými obrázkami"

