@procs = qw(plug_in_web_browser
            gimp_online_main_web_site
            gimp_online_docs_web_site
            gimp_online_bugs_features
            gimp_online_developer_web_site
            gimp_online_roadmap);

%exports = (app => [@procs], lib => []);

$desc = 'Plug-in Compat';
$doc_title = 'gimpplugincompat';
$doc_short_desc = 'Compatibility for removed plug-ins.';
$doc_long_desc = 'Functions that perform the operation of removed scripts or plug-ins, replaced by GIMP, GLib or GTK internal functions.';

1;
