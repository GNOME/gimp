sub plug_in_web_browser {
    $blurb = 'Open a URI';

    $help = <<'HELP';
Open a URI in the user specified software.


For instance, a HTTP URI should open your default web browser.


This PDB procedure is deprecated without any replacement because you
should not need a PDB procedure to open a given URI in your browser.

Instead use the GLib function `g_app_info_launch_default_for_uri()`, or
again the GTK function `gtk_show_uri_on_window()`.

In Script-Fu, you may use `(gimp-show-uri)`.
HELP

    $deprecated = 'NONE';
    $deprecated_since = '3.2';

    &std_pdb_misc;
    $date = '2003-09-16';

    @inargs = (
        { name => 'url', type => 'string',
          desc => 'URI to open' },
    );
    %invoke = (
	code => <<'CODE'
{
  success = g_app_info_launch_default_for_uri (url, NULL, error);
}
CODE
    );
}

sub gimp_online_main_web_site {
    $blurb = 'Main Web Site';

    $help = <<'HELP';
Bookmark to the GIMP web site
HELP

    &std_pdb_misc;
    $date = '2003';

    $deprecated = 'plug-in-web-browser';
    $deprecated_since = '3.2';

    @inargs = (
	{ name => 'run_mode', type => 'enum GimpRunMode', dead => 1,
	  desc => 'The run mode' }
    );
    %invoke = (
	code => <<'CODE'
{
  success = g_app_info_launch_default_for_uri ("https://www.gimp.org/", NULL, error);
}
CODE
    );
}

