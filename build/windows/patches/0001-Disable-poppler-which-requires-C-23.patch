From 7f504a22bba00593039962c9642ba0e44617e345 Mon Sep 17 00:00:00 2001
From: Bruno Lopes <brunvonlope@outlook.com>
Date: Tue, 14 Apr 2026 11:29:00 -0300
Subject: [PATCH] Disable poppler which requires C++23

---
 meson.build                 | 9 ---------
 plug-ins/common/meson.build | 9 ---------
 2 files changed, 18 deletions(-)

diff --git a/meson.build b/meson.build
index d53ab4c5f6..c027fa5e4e 100644
--- a/meson.build
+++ b/meson.build
@@ -1064,13 +1064,6 @@ if get_option('webkit-unmaintained')
 endif
 conf.set('HAVE_WEBKIT', get_option('webkit-unmaintained'))
 
-poppler_minver = '0.69.0'
-poppler_data_minver = '0.4.9'
-poppler = [
-  dependency('poppler-glib', version: '>='+poppler_minver),
-  dependency('poppler-data', version: '>='+poppler_data_minver),
-]
-
 cairopdf_minver = '1.12.2'
 cairopdf = dependency('cairo-pdf', version: '>='+cairopdf_minver,
   required: get_option('cairo-pdf')
@@ -1823,8 +1816,6 @@ install_conf.set('LIBPNG_REQUIRED_VERSION',       libpng_minver)
 install_conf.set('OPENEXR_REQUIRED_VERSION',      openexr_minver)
 install_conf.set('OPENJPEG_REQUIRED_VERSION',     openjpeg_minver)
 install_conf.set('PANGO_REQUIRED_VERSION',        pango_minver)
-install_conf.set('POPPLER_DATA_REQUIRED_VERSION', poppler_data_minver)
-install_conf.set('POPPLER_REQUIRED_VERSION',      poppler_minver)
 install_conf.set('PYGOBJECT_REQUIRED_VERSION',    pygobject_minver)
 install_conf.set('PYTHON3_REQUIRED_VERSION',      python3_minver)
 install_conf.set('RSVG_REQUIRED_VERSION',         rsvg_minver)
diff --git a/plug-ins/common/meson.build b/plug-ins/common/meson.build
index d76525d112..203ad85742 100644
--- a/plug-ins/common/meson.build
+++ b/plug-ins/common/meson.build
@@ -36,9 +36,6 @@ common_plugins_list = [
   { 'name': 'file-paa', },
   { 'name': 'file-pat', },
   { 'name': 'file-pcx', },
-  { 'name': 'file-pdf-load',
-    'deps': [ poppler ],
-  },
   { 'name': 'file-pix', },
   { 'name': 'file-png',
     'deps': [ libpng, lcms ],
@@ -119,12 +116,6 @@ if libmng.found()
   }
 endif
 
-if cairopdf.found()
-  common_plugins_list += { 'name': 'file-pdf-export',
-    'deps': [ poppler, cairopdf ],
-  }
-endif
-
 if ghostscript.found()
   common_plugins_list += { 'name': 'file-ps',
     'deps': [ ghostscript, ],
-- 
2.50.1 (Apple Git-155)

