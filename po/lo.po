msgstr "ສຳເນົາຂໍ້ມູນບັກໃສ່ຄລິບບອດໂດຍການຄລິກ: "

#: app/widgets/gimpcriticaldialog.c:257 app/widgets/gimpcriticaldialog.c:659
msgid "Open our bug tracker in the browser by clicking: "
msgstr "ເປີດຕົວຕິດຕາມບັກຂອງພວກເຮົາໃນບຣາວເຊີໂດຍການຄລິກ: "

#: app/widgets/gimpcriticaldialog.c:259 app/widgets/gimpcriticaldialog.c:661
msgid "Create a login if you don't have one yet."
msgstr "ສ້າງບັນຊີເຂົ້າສູ່ລະບົບຫາກທ່ານຍັງບໍ່ມີ."

#: app/widgets/gimpcriticaldialog.c:260 app/widgets/gimpcriticaldialog.c:662
msgid "Paste the clipboard text in a new bug report."
msgstr "ວາງຂໍ້ຄວາມໃນຄລິບບອດໃສ່ໃນລາຍງານບັກໃໝ່."

#: app/widgets/gimpcriticaldialog.c:261 app/widgets/gimpcriticaldialog.c:663
msgid ""
"Add relevant information in English in the bug report explaining what you "
"were doing when this error occurred."
msgstr "ເພີ່ມຂໍ້ມູນທີ່ກ່ຽວຂ້ອງເປັນພາສາອັງກິດໃນລາຍງານບັກເພື່ອອະທິບາຍວ່າທ່ານກຳລັງເຮັດຫຍັງຢູ່ເມື່ອເກີດຄວາມຜິດພາດນີ້."

#: app/widgets/gimpcriticaldialog.c:263
msgid ""
"This error may have left GIMP in an inconsistent state. It is advised to "
"save your work and restart GIMP."
msgstr "ຄວາມຜິດພາດນີ້ອາດເຮັດໃຫ້ GIMP ຢູ່ໃນສະຖານະທີ່ບໍ່ຄົງທີ່. ຂໍແນະນຳໃຫ້ບັນທຶກວຽກຂອງທ່ານ ແລະ ເລີ່ມ GIMP ໃໝ່."

#: app/widgets/gimpcriticaldialog.c:268
msgid ""
"You can also close the dialog directly but reporting bugs is the best way to "
"make your software awesome."
msgstr "ທ່ານສາມາດປິດກ່ອງໂຕ້ຕອບໂດຍກົງໄດ້ ແຕ່ການລາຍງານບັກເປັນວິທີທີ່ດີທີ່ສຸດທີ່ຈະເຮັດໃຫ້ຊອຟແວຂອງທ່ານດີເລີດ."

#: app/widgets/gimpcriticaldialog.c:277
msgid "Copy-paste this whole debug data to report to developers"
msgstr "ສຳເນົາ-ວາງຂໍ້ມູນດີບັກທັງໝົດນີ້ເພື່ອລາຍງານໃຫ້ນັກພັດທະນາ"

#: app/widgets/gimpcriticaldialog.c:416
msgid "The operating system is out of memory or resources."
msgstr "ລະບົບປະຕິບັດການບໍ່ມີໜ່ວຍຄວາມຈຳ ຫຼື ຊັບພະຍາກອນພຽງພໍ."

#: app/widgets/gimpcriticaldialog.c:419
msgid "The specified file was not found."
msgstr "ບໍ່ພົບໄຟລ໌ທີ່ລະບຸ."

#: app/widgets/gimpcriticaldialog.c:422
msgid "The specified path was not found."
msgstr "ບໍ່ພົບເສັ້ນທາງທີ່ລະບຸ."

#: app/widgets/gimpcriticaldialog.c:425
msgid ""
"The .exe file is invalid (non-Microsoft Win32 .exe or error in .exe image)."
msgstr "ໄຟລ໌ .exe ບໍ່ຖືກຕ້ອງ (ບໍ່ແມ່ນ .exe ຂອງ Microsoft Win32 ຫຼື ມີຄວາມຜິດພາດໃນຮູບ .exe)."

#: app/widgets/gimpcriticaldialog.c:428
msgid "The operating system denied access to the specified file."
msgstr "ລະບົບປະຕິບັດການປະຕິເສດການເຂົ້າເຖິງໄຟລ໌ທີ່ລະບຸ."

#: app/widgets/gimpcriticaldialog.c:431
msgid "The file name association is incomplete or invalid."
msgstr "ການຈັບຄູ່ຊື່ໄຟລ໌ບໍ່ສົມບູນ ຫຼື ບໍ່ຖືກຕ້ອງ."

#: app/widgets/gimpcriticaldialog.c:434
msgid "DDE transaction busy"
msgstr "ທຸລະກຳ DDE ກຳລັງຫຍຸ້ງ"

#: app/widgets/gimpcriticaldialog.c:437
msgid "The DDE transaction failed."
msgstr "ທຸລະກຳ DDE ລົ້ມເຫຼວ."

#: app/widgets/gimpcriticaldialog.c:440
msgid "The DDE transaction timed out."
msgstr "ທຸລະກຳ DDE ໝົດເວລາ."

#: app/widgets/gimpcriticaldialog.c:443
msgid "The specified DLL was not found."
msgstr "ບໍ່ພົບ DLL ທີ່ລະບຸ."

#: app/widgets/gimpcriticaldialog.c:446
msgid "There is no application associated with the given file name extension."
msgstr "ບໍ່ມີແອັບພລິເຄຊັນທີ່ຈັບຄູ່ກັບນາມສະກຸນໄຟລ໌ທີ່ໃຫ້."

#: app/widgets/gimpcriticaldialog.c:449
msgid "There was not enough memory to complete the operation."
msgstr "ມີໜ່ວຍຄວາມຈຳບໍ່ພຽງພໍທີ່ຈະເຮັດໃຫ້ການດຳເນີນການສຳເລັດ."

#: app/widgets/gimpcriticaldialog.c:452
msgid "A sharing violation occurred."
msgstr "ເກີດການລະເມີດການແບ່ງປັນ."

#: app/widgets/gimpcriticaldialog.c:455
msgid "Unknown Microsoft Windows error."
msgstr "ຄວາມຜິດພາດທີ່ບໍ່ຮູ້ຈັກຂອງ Microsoft Windows."

#: app/widgets/gimpcriticaldialog.c:458
#, c-format
msgid "Failed to open '%s': %s"
msgstr "ເປີດ '%s' ລົ້ມເຫຼວ: %s"

#: app/widgets/gimpcriticaldialog.c:621
#, c-format
msgid "GIMP crashed with a fatal error: %s"
msgstr "GIMP ຂັດຂ້ອງດ້ວຍຄວາມຜິດພາດຮ້າຍແຮງ: %s"

#. First error. Let's just display it.
#: app/widgets/gimpcriticaldialog.c:628
#, c-format
msgid "GIMP encountered an error: %s"
msgstr "GIMP ພົບຄວາມຜິດພາດ: %s"

#. Let's not display all errors. They will be in the bug report
#. * part anyway.
#.
#: app/widgets/gimpcriticaldialog.c:636
#, c-format
msgid "GIMP encountered several critical errors!"
msgstr "GIMP ພົບຄວາມຜິດພາດຮ້າຍແຮງຫຼາຍຢ່າງ!"

#: app/widgets/gimpcriticaldialog.c:688
msgid "_Restart GIMP"
msgstr "_ເລີ່ມ GIMP ໃໝ່"

