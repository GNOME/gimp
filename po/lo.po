#: app/about.h:38
msgid ""
"GIMP is free software: you can redistribute it and/or modify it under the "
"terms of the GNU General Public License as published by the Free Software "
"Foundation; either version 3 of the License, or (at your option) any later "
"version.\n"
"\n"
"GIMP is distributed in the hope that it will be useful, but WITHOUT ANY "
"WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS "
"FOR A PARTICULAR PURPOSE.  See the GNU General Public License for more "
"details.\n"
"\n"
"You should have received a copy of the GNU General Public License along with "
"GIMP. If not, see: https://www.gnu.org/licenses/"
msgstr "GIMP ເປັນຊັອບແວເສລີ: ທ່ານສາມາດແຈກຢາຍຕໍ່ ແລະ/ຫຼື ດັດແປງມັນໄດ້ພາຍໃຕ້ເງື່ອນໄຂຂອງສັນຍາອະນຸຍາດສາທາລະນະທົ່ວໄປຂອງ GNU ຕາມທີ່ເຜີຍແຜ່ໂດຍມູນນິທິຊັອບແວເສລີ; ບໍ່ວ່າຈະເປັນເວີຊັນ 3 ຂອງສັນຍາອະນຸຍາດ, ຫຼື (ຕາມທີ່ທ່ານເລືອກ) ເວີຊັນໃດກໍໄດ້ທີ່ໃໝ່ກວ່າ.\n\nGIMP ຖືກແຈກຢາຍໂດຍຫວັງວ່າມັນຈະເປັນປະໂຫຍດ, ແຕ່ບໍ່ມີການຮັບປະກັນໃດໆ; ແມ່ນແຕ່ການຮັບປະກັນໂດຍທາງອ້ອມກ່ຽວກັບຄວາມສາມາດໃນການຄ້າ ຫຼື ຄວາມເໝາະສົມສຳລັບຈຸດປະສົງສະເພາະ. ເບິ່ງລາຍລະອຽດເພີ່ມເຕີມໃນສັນຍາອະນຸຍາດສາທາລະນະທົ່ວໄປຂອງ GNU.\n\nທ່ານຄວນຈະໄດ້ຮັບສຳເນົາຂອງສັນຍາອະນຸຍາດສາທາລະນະທົ່ວໄປຂອງ GNU ມາພ້ອມກັບ GIMP. ຖ້າບໍ່, ເບິ່ງທີ່: https://www.gnu.org/licenses/"

#. TRANSLATORS: title for info message in terminal window
#: app/app.c:534
msgid "INFO"
msgstr "ຂໍ້ມູນ"

#. TRANSLATORS: info message displayed in terminal window.
#: app/app.c:536
msgid ""
"GIMP is now running as a background process. You can quit anytime with Ctrl-"
"C (SIGINT)."
msgstr "GIMP ກຳລັງເຮັດວຽກເປັນໂປຣເຊສພື້ນຫຼັງ. ທ່ານສາມາດອອກໄດ້ທຸກເວລາດ້ວຍ Ctrl-C (SIGINT)."

#. TRANSLATORS: info message displayed in terminal window.
#: app/app.c:539
msgid "If you wanted to quit immediately instead, call GIMP with --quit."
msgstr "ຖ້າທ່ານຕ້ອງການອອກທັນທີ, ໃຫ້ເອີ້ນ GIMP ດ້ວຍ --quit."

#: app/gimp-update.c:444
#, c-format
msgid ""
"A new version of GIMP (%s) was released.\n"
"It is recommended to update."
msgstr "GIMP ເວີຊັນໃໝ່ (%s) ໄດ້ຖືກປ່ອຍອອກມາແລ້ວ.\nແນະນຳໃຫ້ອັບເດດ."

#: app/gimp-version.c:72
#, c-format
msgid "%s version %s"
msgstr "%s ເວີຊັນ %s"

#: app/gimp-version.c:164 app/gimp-version.c:283
#, c-format
msgid "using %s version %s (compiled against version %s)"
msgstr "ໃຊ້ %s ເວີຊັນ %s (ຄອມໄພລ໌ທຽບກັບເວີຊັນ %s)"

#: app/gimp-version.c:305
#, c-format
msgid "using %s version %s"
msgstr "ໃຊ້ %s ເວີຊັນ %s"

#. This must be localized with the system language itself, before we
#. * apply any other language.
#.
#: app/language.c:69
msgid "System Language"
msgstr "ພາສາລະບົບ"

#: app/main.c:164
msgid "Show version information and exit"
msgstr "ສະແດງຂໍ້ມູນເວີຊັນ ແລະ ອອກ"

#: app/main.c:169
msgid "Show license information and exit"
msgstr "ສະແດງຂໍ້ມູນສັນຍາອະນຸຍາດ ແລະ ອອກ"

#: app/main.c:174
msgid "Be more verbose"
msgstr "ສະແດງຂໍ້ມູນລະອຽດຫຼາຍຂຶ້ນ"

#: app/main.c:179
msgid "Start a new GIMP instance"
msgstr "ເລີ່ມ GIMP ອັນໃໝ່"

#: app/main.c:184
msgid "Open images as new"
msgstr "ເປີດຮູບພາບເປັນອັນໃໝ່"

#: app/main.c:189
msgid "Run without a user interface"
msgstr "ເຮັດວຽກໂດຍບໍ່ມີສ່ວນຕິດຕໍ່ຜູ້ໃຊ້"

#: app/main.c:194
msgid "Do not load brushes, gradients, patterns, ..."
msgstr "ບໍ່ຕ້ອງໂຫຼດຫົວແປງ, ສີໄລ່ລະດັບ, ລວດລາຍ, ..."

#: app/main.c:199
msgid "Do not load any fonts"
msgstr "ບໍ່ຕ້ອງໂຫຼດຟອນໃດໆ"

#: app/main.c:204
msgid "Do not show a splash screen"
msgstr "ບໍ່ຕ້ອງສະແດງໜ້າຈໍເລີ່ມຕົ້ນ"

#: app/main.c:209
msgid "Do not use shared memory between GIMP and plug-ins"
msgstr "ບໍ່ໃຊ້ໜ່ວຍຄວາມຈຳຮ່ວມກັນລະຫວ່າງ GIMP ແລະ ສ່ວນເສີມ"

#: app/main.c:214
msgid "Do not use special CPU acceleration functions"
msgstr "ບໍ່ໃຊ້ຟັງກ໌ຊັນເລັ່ງຄວາມໄວ CPU ແບບພິເສດ"

#: app/main.c:219
msgid "Use an alternate sessionrc file"
msgstr "ໃຊ້ໄຟລ໌ sessionrc ສຳຮອງ"

#: app/main.c:224
msgid "Use an alternate user gimprc file"
msgstr "ໃຊ້ໄຟລ໌ gimprc ຂອງຜູ້ໃຊ້ສຳຮອງ"

#: app/main.c:229
msgid "Use an alternate system gimprc file"
msgstr "ໃຊ້ໄຟລ໌ gimprc ຂອງລະບົບສຳຮອງ"

#: app/main.c:234
msgid "Batch command to run (can be used multiple times)"
msgstr "ຄຳສັ່ງແບບຊຸດເພື່ອເຮັດວຽກ (ໃຊ້ໄດ້ຫຼາຍຄັ້ງ)"

#: app/main.c:239
msgid "The procedure to process batch commands with"
msgstr "ຂັ້ນຕອນການປະມວນຜົນຄຳສັ່ງແບບຊຸດ"

#: app/main.c:244
msgid "Quit immediately after performing requested actions"
msgstr "ອອກທັນທີຫຼັງຈາກດຳເນີນການຕາມທີ່ຮ້ອງຂໍແລ້ວ"

#: app/main.c:249
msgid "Send messages to console instead of using a dialog"
msgstr "ສົ່ງຂໍ້ຄວາມໄປທີ່ຄອນໂຊນແທນການໃຊ້ກ່ອງໂຕ້ຕອບ"

#. don't translate the mode names (off|on|warn)
#: app/main.c:255
msgid "PDB compatibility mode (off|on|warn)"
msgstr "ໂໝດເຂົ້າກັນໄດ້ຂອງ PDB (off|on|warn)"

#. don't translate the mode names (never|query|always)
#: app/main.c:261
msgid "Debug in case of a crash (never|query|always)"
msgstr "ດີບັກໃນກໍລະນີເກີດບັນຫາ (never|query|always)"

#: app/main.c:266
msgid "Enable non-fatal debugging signal handlers"
msgstr "ເປີດໃຊ້ໂຕຈັດການສັນຍານດີບັກທີ່ບໍ່ຮ້າຍແຮງ"

#: app/main.c:271
msgid "Make all warnings fatal"
msgstr "ເຮັດໃຫ້ທຸກຄຳເຕືອນເປັນຂໍ້ຜິດພາດຮ້າຍແຮງ"

#: app/main.c:276
msgid "Output a gimprc file with default settings"
msgstr "ສົ່ງອອກໄຟລ໌ gimprc ທີ່ມີຄ່າເລີ່ມຕົ້ນ"

#: app/main.c:292
msgid "Output a sorted list of deprecated procedures in the PDB"
msgstr "ສົ່ງອອກລາຍຊື່ຂັ້ນຕອນທີ່ລ້າສະໄໝໃນ PDB ທີ່ຮຽງລຳດັບແລ້ວ"

#: app/main.c:297
msgid "Show a preferences page with experimental features"
msgstr "ສະແດງໜ້າການຕັ້ງຄ່າທີ່ມີຄຸນສົມບັດທົດລອງ"

#: app/main.c:302
msgid "Show an image submenu with debug actions"
msgstr "ສະແດງເມນູຍ່ອຍຮູບພາບທີ່ມີການກະທຳດີບັກ"

#: app/main.c:757
msgid "[FILE|URI...]"
msgstr "[ໄຟລ໌|URI...]"

#: app/main.c:787
msgid ""
"GIMP could not initialize the graphical user interface.\n"
"Make sure a proper setup for your display environment exists."
msgstr "GIMP ບໍ່ສາມາດເລີ່ມຕົ້ນສ່ວນຕິດຕໍ່ຜູ້ໃຊ້ແບບກຣາບຟິກໄດ້.\nກວດສອບໃຫ້ແນ່ໃຈວ່າມີການຕັ້ງຄ່າທີ່ເໝາະສົມສຳລັບສະພາບແວດລ້ອມການສະແດງຜົນຂອງທ່ານ."

#: app/main.c:851
