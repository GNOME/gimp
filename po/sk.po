#: app/config/gimpconfig-file.c:223 app/core/gimp-tags.c:145
#: app/gui/themes.c:722 app/tools/gimpfiltertool-settings.c:229
#, c-format
msgid "Error writing '%s': %s"
msgstr "Chyba pri zapisovaní „%s“: %s"

#: app/config/gimpconfig-file.c:184 app/plug-in/gimpenvirontable.c:374
#: app/plug-in/gimpinterpreterdb.c:331 app/tools/gimpfiltertool-settings.c:182
#, c-format
msgid "Error reading '%s': %s"
msgstr "Chyba počas čítania „%s“: %s"

#: app/config/gimpconfig-file.c:259
#, c-format
msgid ""
"There was an error parsing your '%s' file. Default values will be used. A "
"backup of your configuration has been created at '%s'."
msgstr ""
"Vyskytla sa chyba počas analyzovania vášho súboru „%s“. Použijú sa "
"predvolené hodnoty. Bola vytvorená záloha vašej konfigurácie v „%s“."

#: app/config/gimpcoreconfig.c:829 app/dialogs/preferences-dialog.c:1915
msgid "Pattern syntax for searching and selecting items:"
msgstr "Syntax vzorov na vyhľadávanie a výber položiek:"

# titulok dialógového okna
#: app/config/gimpdialogconfig.c:319 app/core/gimplayer.c:406
msgid "Layer"
msgstr "Vrstva"

#: app/config/gimpdialogconfig.c:426 app/core/gimpchannel.c:238
#: app/operations/gimpcurvesconfig.c:120 app/operations/gimplevelsconfig.c:135
#: app/operations/gimpoperationthreshold.c:95
#: app/widgets/gimpchanneltreeview.c:333
msgid "Channel"
msgstr "Kanál"

# titulok dialógového okna (okrem iného)
#: app/config/gimpdialogconfig.c:440 app/path/gimppath.c:215
#: app/widgets/gimppathtreeview.c:254
msgid "Path"
msgstr "Cesta"

#: app/config/gimpdisplayconfig.c:143
msgid "Transparency custom color 1"
msgstr "Vlastná farba priehľadnosti 1"

#: app/config/gimpdisplayconfig.c:151
msgid "Transparency custom color 2"
msgstr "Vlastná farba priehľadnosti 2"

# tooltip
#. Not all strings defined here are used in the user interface
#. *  (the preferences dialog mainly) and only those that are should
#. *  be marked for translation.
#.
#: app/config/gimprc-blurbs.h:11
msgid ""
"When enabled, an image will become the active image when its image window "
"receives the focus. This is useful for window managers using \"click to "
"focus\"."
msgstr ""
"Keď je povolené, obrázok sa stane aktívny, keď sa okno obrázka stane "
"aktívnym. Toto je užitočné, keď správca okien používa nastavenie „aktívne po "
"kliknutí“."

# tooltip
#: app/config/gimprc-blurbs.h:21 app/config/gimprc-blurbs.h:35
msgid "Sets the dynamics search path."
msgstr "Nastavuje hľadanie cesty pre dynamiku."

# tooltip
#: app/config/gimprc-blurbs.h:24
msgid "Specifies the language the user interface was previously displayed in."
msgstr "Určuje jazyk, v ktorom bolo rozhranie naposledy zobrazené."

#: app/config/gimprc-blurbs.h:27
msgid "The comment for the last known release."
msgstr "Komentár k poslednému známemu vydaniu."

#: app/config/gimprc-blurbs.h:30
msgid "Show a welcome dialog when GIMP starts."
msgstr "Zobraziť dialógové okno s privítaním pri spustení GIMPu."

# tooltip
#: app/config/gimprc-blurbs.h:40
msgid ""
"Sets the canvas padding color used if the padding mode is set to custom "
"color."
msgstr ""
"Nastavuje farbu obtekania plátna, ak je nastavený režim obtekania na vlastnú "
"farbu."

#: app/config/gimprc-blurbs.h:44
msgid ""
"Specifies whether to keep the canvas padding when \"View -> Show All\" is "
"enabled."
msgstr ""
"Určuje, či sa má ponechať výplň plátna, keď je zapnuté „Zobrazenie → "
"Zobraziť všetko“."

# tooltip
#: app/config/gimprc-blurbs.h:48
msgid "Specifies how the area around the image should be drawn."
msgstr "Určuje, ako sa má vykresliť oblasť okolo obrázka."

#: app/config/gimprc-blurbs.h:51
msgid ""
"Check for availability of GIMP updates through background internet queries."
msgstr ""
"Kontrolovať dostupnosť aktualizácií GIMPu pomocou internetových dotazov na "
"pozadí."

#: app/config/gimprc-blurbs.h:54
msgid "Timestamp of the last update check."
msgstr "Časový údaj poslednej kontroly aktualizácií."

# tooltip
#: app/config/gimprc-blurbs.h:60
msgid "What to do when opening a file with an embedded ICC color profile."
msgstr "Čo robiť pri otváraní súboru so zabudovaným profilom farieb ICC."

# tooltip
#: app/config/gimprc-blurbs.h:63
msgid "Sets the default folder path for all color profile file dialogs."
msgstr ""
"Nastavuje predvolenú cestu k priečinku pre všetky dialógové okná súborov "
"farebných profilov."

# tooltip
#: app/config/gimprc-blurbs.h:66
msgid "Sets the type of mouse pointers to use."
msgstr "Nastavuje typ kurzoru myši, ktorý bude GIMP používať."

# tooltip
# PM: nie som celkom spokojný, ale kedze neviem vymysliet nic lepsie, uvidíme
# čo na to Paľo
#: app/config/gimprc-blurbs.h:69
msgid "Sets the handedness for cursor positioning."
msgstr "Nastavuje uchytenie pozície kurzora rukou, pre pravákov alebo ľavákov"

# tooltip
#: app/config/gimprc-blurbs.h:72
msgid ""
"Context-dependent mouse pointers are helpful.  They are enabled by default.  "
"However, they require overhead that you may want to do without."
msgstr ""
"Kurzory závisiace na kontexte sú užitočné. Implicitne sú povolené. Môžu však "
"viac zaťažiť systém."

#: app/config/gimprc-blurbs.h:88
msgid "Merge menu and title bar (client-side decoration)"
msgstr "Zlúčiť ponuku a titulkový panel (dekorácia na strane klienta)"

#: app/config/gimprc-blurbs.h:91
msgid "Show full image content by default."
msgstr "Predvolene zobraziť úplný obsah obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:94
msgid ""
"When enabled, this will ensure that each pixel of an image gets mapped to a "
"pixel on the screen."
msgstr ""
"Keď je povolené, zabezpečí to, aby každý pixel na obrázku bol namapovaný na "
"pixel na obrazovke."

# tooltip
#: app/config/gimprc-blurbs.h:119
msgid "This is the distance in pixels where Guide and Grid snapping activates."
msgstr ""
"Toto je vzdialenosť v pixeloch, kde sa aktivuje priťahovanie k vodidlám a "
"mriežke."

#: app/config/gimprc-blurbs.h:123
msgid "Snap to guides by default in new image windows."
msgstr "Prichytávať k vodidlám predvolene v nových oknách obrázkov."

# tooltip
#: app/config/gimprc-blurbs.h:126
msgid "Snap to the grid by default in new image windows."
msgstr "Predvolene prichytávať k mriežke v nových oknách obrázkov."

#: app/config/gimprc-blurbs.h:129
msgid "Snap to the canvas edges by default in new image windows."
msgstr "Prichytávať k okrajom plátna predvolene v nových oknách obrázkov."

# tooltip
#: app/config/gimprc-blurbs.h:132
msgid "Snap to the active path by default in new image windows."
msgstr "Predvolene prichytávať k aktívnej ceste v nových oknách obrázkov."

# tooltip
#: app/config/gimprc-blurbs.h:135
msgid "Snap to the layers bounding boxes by default in new image windows."
msgstr ""
"Predvolene prichytávať k ohraničujúcim rámčekom vrstiev v nových oknách "
"obrázkov."

# tooltip
#: app/config/gimprc-blurbs.h:138
msgid ""
"Snap to the equidistance between three bounding boxes by default in new "
"image windows."
msgstr ""
"Predvolene prichytávať k ekvidistancii medzi troma ohraničujúcimi rámčekmi v "
"nových oknách obrázkov."

# tooltip
#: app/config/gimprc-blurbs.h:141
msgid ""
"Tools such as fuzzy-select and bucket fill find regions based on a seed-fill "
"algorithm.  The seed fill starts at the initially selected pixel and "
"progresses in all directions until the difference of pixel intensity from "
"the original is greater than a specified threshold. This value represents "
"the default threshold."
msgstr ""
"Nástroje ako približný výber a plechovka hľadajú oblasti algoritmom "
"semienkového vyplňovania. Semienkové vyplňovanie začne na pôvodne vybranom "
"pixeli a prebieha vo všetkých smeroch, pokiaľ nie je rozdiel intenzity "
"pixelu od originálu väčší ako zadaný prah. Táto hodnota reprezentuje "
"predvolený prah."

# tooltip
#: app/config/gimprc-blurbs.h:154
msgid ""
"The window type hint that is set on dock windows and the toolbox window. "
"This may affect the way your window manager decorates and handles these "
"windows."
msgstr ""
"Typ okna, ktorý je nastavený na dokovacích oknách. Toto môže mať vplyv na "
"to, ako váš správca okien orámuje dokovacie okná a ako s nimi bude narábať."

# tooltip
#: app/config/gimprc-blurbs.h:174
msgid "When enabled, the selected brush will be used for all tools."
msgstr "Keď je povolené, bude zvolený štetec použitý pre všetky nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:177
msgid "When enabled, the selected dynamics will be used for all tools."
msgstr "Keď je povolené, bude zvolená dynamika použitá pre všetky nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:183
msgid "When enabled, the selected gradient will be used for all tools."
msgstr "Keď je povolené, bude zvolený prechod použitý pre všetky nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:186
msgid "When enabled, the selected pattern will be used for all tools."
msgstr "Keď je povolené, bude zvolený vzor použitý pre všetky nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:192
msgid ""
"When enabled, the selected auto expand layer settings will be used for all "
"tools."
msgstr ""
"Keď je povolené, vybrané nastavenia automatického roztiahnutia vrstvy sa "
"použijú pre všetky nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:203
msgid "Sets the browser used by the help system."
msgstr "Nastavuje prehliadač, ktorý bude využívaný systémom pomocníka."

# tooltip
#: app/config/gimprc-blurbs.h:211
msgid "How many recent settings to keep around in filter tools."
msgstr "Koľko nedávnych nastavení sa má uchovávať v nástrojoch filtrov."

#: app/config/gimprc-blurbs.h:214
msgid "Default to the last used settings in filter tools."
msgstr "Predvolene ponúkať naposledy použité nastavenia vo nástrojoch filtrov."

# tooltip
#: app/config/gimprc-blurbs.h:217
msgid "Sets the text to appear in image window status bars."
msgstr "Nastavuje text, ktorý sa objaví v stavových lištách okna obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:220
msgid "Sets the text to appear in image window titles."
msgstr "Nastavuje text, ktorý sa objaví v titulkových pruhoch okna obrázka."

#: app/config/gimprc-blurbs.h:223
msgid ""
"Promote imported images to floating point precision. Does not apply to "
"indexed images."
msgstr ""
"Previesť importované obrázky na presnosť desatinných čísel. Nevzťahuje sa na "
"indexované obrázky."

#: app/config/gimprc-blurbs.h:227
msgid ""
"When promoting imported images to floating point precision, also add minimal "
"noise in order to distribute color values a bit."
msgstr ""
"Pri prevode importovaných obrázkov na presnosť desatinných čísel tiež pridať "
"minimálny šum na mierne rozloženie farebných hodnôt."

#: app/config/gimprc-blurbs.h:231
msgid "Add an alpha channel to all layers of imported images."
msgstr "Pridať alfa kanál do všetkých vrstiev importovaných obrázkov."

#: app/config/gimprc-blurbs.h:234
msgid "Which plug-in to use for importing raw digital camera files."
msgstr ""
"Ktorý zásuvný modul sa má použiť na import surových súborov z digitálnych "
"fotoaparátov."

#: app/config/gimprc-blurbs.h:237
msgid "Export file type used by default."
msgstr "Predvolený typ súboru pre export."

# tooltip
#: app/config/gimprc-blurbs.h:240
msgid "Export the image's color profile by default."
msgstr "Predvolene exportovať farebný profil obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:243
msgid "Export the image's comment by default."
msgstr "Predvolene exportovať komentár obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:246 app/dialogs/preferences-dialog.c:1566
msgid "Export the image's thumbnail by default"
msgstr "Predvolene exportovať miniatúru obrázka"

#. Translators: tooltip for configuration option (checkbox).
#. * It determines how file export plug-ins handle Exif by default.
#.
#: app/config/gimprc-blurbs.h:252
msgid "Export Exif metadata by default."
msgstr "Predvolene exportovať metadáta Exif."

#. Translators: tooltip for configuration option (checkbox).
#. * It determines how file export plug-ins handle XMP by default.
#.
#: app/config/gimprc-blurbs.h:258
msgid "Export XMP metadata by default."
msgstr "Predvolene exportovať metadáta XMP."

#. Translators: tooltip for configuration option (checkbox).
#. * It determines how file export plug-ins handle IPTC by default.
#.
#: app/config/gimprc-blurbs.h:264
msgid "Export IPTC metadata by default."
msgstr "Predvolene exportovať metadáta IPTC."

#. Translators: tooltip for configuration option (checkbox).
#. * It determines what metadata is updated when exporting.
#.
#: app/config/gimprc-blurbs.h:270
msgid ""
"When enabled, add and update metadata automatically. When disabled, only the "
"minimum necessary metadata changes are made, without changing modification "
"date, synchronizing tags, or updating the software and change history "
"metadata."
msgstr ""
"Keď je povolené, metádáta budú automaticky pridané a aktualizované. Keď je "
"zakázané, vykonávajú sa len minimálne nevyhnutné zmeny metádát bez zmeny "
"dátumu úpravy, synchronizácie značiek alebo aktualizácie metádát softvéru a "
"histórie zmien."

#: app/config/gimprc-blurbs.h:276
msgid "Try generating debug data for bug reporting when appropriate."
msgstr "Pokúsiť sa generovať ladiace dáta pre hlásenie chýb, keď je to vhodné."

#: app/config/gimprc-blurbs.h:279
msgid "Sets the preferred pen and touch input API."
msgstr "Nastavuje uprednostňované API pre vstup perom a dotykom."

# tooltip
#: app/config/gimprc-blurbs.h:282
msgid ""
"When enabled, this will ensure that the full image is visible after a file "
"is opened, otherwise it will be displayed with a scale of 1:1."
msgstr ""
"Keď je povolené, zabezpečí to, že celý obrázok bude viditeľný pri otvorení "
"súboru, inak sa obrázok zobrazí v mierke 1:1."

#: app/config/gimprc-blurbs.h:286
msgid ""
"Whether to zoom based on distance moved or time spent moving, when zooming "
"via dragging the mouse."
msgstr ""
"Či sa má priblíženie riadiť vzdialenosťou pohybu alebo časom stráveným "
"pohybom pri priblížení ťahaním myši."

#: app/config/gimprc-blurbs.h:290
msgid ""
"Adjusts the rate at which dragging the mouse will zoom the canvas, in "
"percentage."
msgstr "Nastavuje rýchlosť, akou ťahanie myši priblíži plátno, v percentách."

# tooltip
#: app/config/gimprc-blurbs.h:294
msgid ""
"Sets the level of interpolation used for scaling and other transformations."
msgstr ""
"Nastavuje úroveň interpolácie použitej pri zmene mierky a iných "
"transformáciách."

# tooltip
#: app/config/gimprc-blurbs.h:301
msgid "Specifies the language to use for the user interface."
msgstr "Nastavuje jemnosť vykreslenia kurzoru myši, ktorý bude GIMP používať."

#: app/config/gimprc-blurbs.h:304
msgid ""
"The last known release version of GIMP as queried from official website."
msgstr "Posledná známa verzia GIMPu podľa oficiálnej webovej stránky."

#: app/config/gimprc-blurbs.h:307
msgid "The version of GIMP config files."
msgstr "Verzia konfiguračných súborov GIMPu."

# tooltip
#: app/config/gimprc-blurbs.h:310
msgid "How many recently opened image filenames to keep on the File menu."
msgstr ""
"Koľko názvov nedávno otvorených obrázkov bude udržovaných v ponuke Súbor."

#: app/config/gimprc-blurbs.h:313
msgid "The timestamp for the last known release date."
msgstr "Časový údaj posledného známeho dátumu vydania."

#: app/config/gimprc-blurbs.h:316
msgid "The last revision number for the release."
msgstr "Posledné číslo revízie pre dané vydanie."

# tooltip
#: app/config/gimprc-blurbs.h:319
msgid ""
"Speed of marching ants in the selection outline.  This value is in "
"milliseconds (less time indicates faster marching)."
msgstr ""
"Rýchlosť bežiaceho čiarkovania v obvode výberu. Táto hodnota je v "
"milisekundách (menší čas znamená rýchlejší beh)."

# tooltip
#: app/config/gimprc-blurbs.h:323
msgid ""
"GIMP will warn the user if an attempt is made to create an image that would "
"take more memory than the size specified here."
msgstr ""
"GIMP bude varovať používateľa pri pokuse vytvoriť obrázok, ktorý by zabral "
"viac pamäte ako je tu určená veľkosť."

# tooltip
#: app/config/gimprc-blurbs.h:327
msgid "How to handle \"Orientation\" metadata when opening a file."
msgstr "Ako narábať s metadátami „Orientácia“ pri otváraní súboru."

# tooltip
#: app/config/gimprc-blurbs.h:336
msgid ""
"Sets the monitor's horizontal resolution, in dots per inch.  If set to 0, "
"forces the X server to be queried for both horizontal and vertical "
"resolution information."
msgstr ""
"Nastavuje vodorovné rozlíšenie monitoru v bodoch na palec. Ak je nastavené "
"na 0, vynúti získanie informácií o vodorovnom a zvislom rozlíšení od X "
"serveru."

# tooltip
#: app/config/gimprc-blurbs.h:341
msgid ""
"Sets the monitor's vertical resolution, in dots per inch.  If set to 0, "
"forces the X server to be queried for both horizontal and vertical "
"resolution information."
msgstr ""
"Nastavuje zvislé rozlíšenie monitoru v bodoch na palec. Ak je nastavené na "
"0, vynúti získanie informácií o vodorovnom a zvislom rozlíšení od X serveru."

# tooltip
#: app/config/gimprc-blurbs.h:346
msgid "When enabled, non-visible layers can be edited as normal."
msgstr "Keď je povolené, neviditeľné vrstvy možno upravovať ako bežné vrstvy."

# tooltip
#: app/config/gimprc-blurbs.h:349
msgid ""
"If enabled, the move tool sets the edited layer or path as active.  This "
"used to be the default behavior in older versions."
msgstr ""
"Ak je povolené, nástroj na presun nastaví upravovanú vrstvu alebo cestu ako "
"aktívnu. Toto bolo predvolené správanie v starších verziách."

# tooltip
#: app/config/gimprc-blurbs.h:358
msgid ""
"Sets the size of the navigation preview available in the lower right corner "
"of the image window."
msgstr ""
"Nastavuje veľkosť navigačného náhľadu dostupného v pravom dolnom rohu okna "
"obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:362
msgid "Sets how many threads GIMP should use for operations that support it."
msgstr ""
"Nastavuje počet vlákien, ktoré má GIMP používať pre operácie, ktoré to "
"podporujú."

# tooltip
#: app/config/gimprc-blurbs.h:384
msgid ""
"Sets whether GIMP should create previews of layers and channels. Previews in "
"the layers and channels dialog are nice to have but they can slow things "
"down when working with large images."
msgstr ""
"Nastavuje, či GIMP bude vytvárať náhľady vrstiev a kanálov. Náhľady v "
"dialógovom okne vrstiev a kanálov sú pekné, ale pri veľkých obrázkoch môžu "
"spôsobovať spomalenie."

#: app/config/gimprc-blurbs.h:389
msgid ""
"Sets whether GIMP should create previews of layer groups. Layer group "
"previews are more expensive than ordinary layer previews."
msgstr ""
"Nastavuje, či má GIMP vytvárať náhľady skupín vrstiev. Náhľady skupín "
"vrstiev sú náročnejšie než bežné náhľady vrstiev."

# tooltip
#: app/config/gimprc-blurbs.h:393
msgid ""
"Sets the preview size used for layers and channel previews in newly created "
"dialogs."
msgstr ""
"Nastavuje veľkosť náhľadu na vrstvy a kanály v novovytvorených dialógoch."

#: app/config/gimprc-blurbs.h:397
msgid "Sets the default quick mask color."
msgstr "Nastavuje predvolenú farbu rýchlej masky."

# tooltip
#: app/config/gimprc-blurbs.h:400
msgid ""
"When enabled, the image window will automatically resize itself whenever the "
"physical image size changes. This setting only takes effect in multi-window "
"mode."
msgstr ""
"Keď je povolené, okno obrázka sa automaticky prispôsobí vždy, keď sa zmenia "
"fyzické rozmery obrázka. Toto nastavenie platí iba v režime viacerých okien."

# tooltip
#: app/config/gimprc-blurbs.h:405
msgid ""
"When enabled, the image window will automatically resize itself when zooming "
"into and out of images. This setting only takes effect in multi-window mode."
msgstr ""
"Keď je povolené, okno obrázka sa automaticky prispôsobí pri priblížení a "
"oddialení obrázkov. Toto nastavenie platí iba v režime viacerých okien."

# tooltip
#: app/config/gimprc-blurbs.h:410
msgid "Let GIMP try to restore your last saved session on each startup."
msgstr ""
"Nechá GIMP, aby sa pri každom spustení pokúsil obnoviť vašu poslednú uloženú "
"reláciu."

#: app/config/gimprc-blurbs.h:413
msgid ""
"When enabled, GIMP will try to restore windows on the monitor they were open "
"before.  When disabled, windows will appear on the currently used monitor."
msgstr ""
"Keď je povolené, GIMP sa pokúsi obnoviť okná na monitore, na ktorom boli "
"predtým otvorené. Keď je zakázané, okná sa zobrazia na aktuálne používanom "
"monitore."

# tooltip
#: app/config/gimprc-blurbs.h:418
msgid ""
"Remember the current tool, pattern, color, and brush across GIMP sessions."
msgstr ""
"Zapamätá si aktuálny nástroj, vzor, farbu a štetec medzi reláciami GIMPu."

#: app/config/gimprc-blurbs.h:422
msgid ""
"When enabled, the same tool and tool options will be used for all input "
"devices. No tool switching will occur when the input device changes."
msgstr ""
"Keď je povolené, rovnaký nástroj a voľby nástroja sa použijú pre všetky "
"vstupné zariadenia. Pri zmene vstupného zariadenia nedôjde k prepnutiu "
"nástrojov."

# tooltip
#: app/config/gimprc-blurbs.h:427
msgid ""
"Keep a permanent record of all opened and saved files in the Recent "
"Documents list."
msgstr ""
"Ponechá trvalý záznam o všetkých otvorených a uložených súboroch v zozname "
"Nedávne dokumenty."

#: app/config/gimprc-blurbs.h:431
msgid "Save the positions and sizes of the main dialogs when GIMP exits."
msgstr "Uloží pozície a veľkosť hlavných dialógov pri ukončení GIMPu."

#: app/config/gimprc-blurbs.h:434
msgid "Save the tool options when GIMP exits."
msgstr "Uloží zmenené klávesové skratky pri ukončení GIMPu."

# tooltip
#: app/config/gimprc-blurbs.h:440
msgid ""
"When enabled, all paint tools will show a preview of the current brush's "
"outline."
msgstr ""
"Keď je povolené, všetky kresliace nástroje budú zobrazovať náhľad obrysu "
"aktuálneho štetca."

# tooltip
#: app/config/gimprc-blurbs.h:444
msgid ""
"When enabled, the brush outline will snap to individual dabs while painting."
msgstr ""
"Keď je povolené, obrys štetca sa bude pri maľovaní prichytávať k jednotlivým "
"ťahom."

# tooltip
#: app/config/gimprc-blurbs.h:448
msgid ""
"When enabled, dialogs will show a help button that gives access to the "
"related help page.  Without this button, the help page can still be reached "
"by pressing F1."
msgstr ""
"Keď je povolené, dialógové okná budú zobrazovať tlačidlo pomocníka, s "
"prístupom k zodpovedajúcej stránke. Bez tohoto tlačidla, stránku pomocníka "
"získate stlačením F1."

#: app/config/gimprc-blurbs.h:453
msgid ""
"When enabled, the pointer will be shown over the image while using a paint "
"tool. If both the brush outline and pointer are disabled, the position will "
"be indicated as unobtrusively as possibly."
msgstr ""
"Keď je povolené, ukazovateľ sa zobrazí nad obrázkom pri používaní "
"maľovacieho nástroja. Ak sú obrys štetca aj ukazovateľ zakázané, pozícia "
"bude indikovaná čo najmenej nápadne."

# tooltip
#: app/config/gimprc-blurbs.h:459
msgid ""
"When enabled, the menubar is visible by default. This can also be toggled "
"with the \"View->Show Menubar\" command."
msgstr ""
"Keď je povolené, ponuka je predvolene viditeľná. Toto môže byť zmenené "
"pomocou príkazu „Zobrazenie->Zobraziť ponuku“."

# tooltip
#: app/config/gimprc-blurbs.h:463
msgid ""
"When enabled, the rulers are visible by default. This can also be toggled "
"with the \"View->Show Rulers\" command."
msgstr ""
"Keď je povolené, pravítka sú predvolene viditeľné. Toto môže byť zmenené "
"pomocou príkazu „Zobrazenie->Zobraziť pravítka“."

# tooltip
#: app/config/gimprc-blurbs.h:467
msgid ""
"When enabled, the scrollbars are visible by default. This can also be "
"toggled with the \"View->Show Scrollbars\" command."
msgstr ""
"Keď je povolené, posuvníky sú predvolene viditeľné. Toto môže byť zmenené "
"pomocou príkazu „Zobrazenie->Zobraziť posuvníky“."

# tooltip
#: app/config/gimprc-blurbs.h:471
msgid ""
"When enabled, the statusbar is visible by default. This can also be toggled "
"with the \"View->Show Statusbar\" command."
msgstr ""
"Keď je povolené, stavový riadok bude predvolene viditeľný. Toto môže byť "
"zmenené pomocou príkazu „Zobrazenie->Zobraziť stavovú lištu“."

# tooltip
#: app/config/gimprc-blurbs.h:475
msgid ""
"When enabled, the selection is visible by default. This can also be toggled "
"with the \"View->Show Selection\" command."
msgstr ""
"Keď je povolené, výber je predvolene viditeľný. Toto môže byť zmenené "
"pomocou „Zobrazenie->Zobraziť výber“."

# tooltip
#: app/config/gimprc-blurbs.h:479
msgid ""
"When enabled, the layer boundary is visible by default. This can also be "
"toggled with the \"View->Show Layer Boundary\" command."
msgstr ""
"Keď je povolené, ohraničenie vrstvy je predvolene viditeľné. Toto môže byť "
"zmenené pomocou „Zobrazenie->Zobraziť ohraničenie vrstvy“."

# tooltip
#: app/config/gimprc-blurbs.h:483
msgid ""
"When enabled, the canvas boundary is visible by default. This can also be "
"toggled with the \"View->Show Canvas Boundary\" command."
msgstr ""
"Keď je povolené, ohraničenie plátna je predvolene viditeľné. Toto môžete "
"prepnúť aj pomocou príkazu „Zobrazenie->Zobraziť ohraničenie plátna\"."

# tooltip
#: app/config/gimprc-blurbs.h:487
msgid ""
"When enabled, the guides are visible by default. This can also be toggled "
"with the \"View->Show Guides\" command."
msgstr ""
"Keď je povolené, vodidlá sú predvolene viditeľné. Toto môže byť zmenené "
"pomocou „Zobrazenie->Zobraziť vodidlá“."

# tooltip
#: app/config/gimprc-blurbs.h:491
msgid ""
"When enabled, the grid is visible by default. This can also be toggled with "
"the \"View->Show Grid\" command."
msgstr ""
"Keď je povolené, mriežka je predvolene viditeľná. Toto môže byť zmenené "
"pomocou „Zobraziť->Zobraziť mriežku“."

# tooltip
#: app/config/gimprc-blurbs.h:495
msgid ""
"When enabled, the sample points are visible by default. This can also be "
"toggled with the \"View->Show Sample Points\" command."
msgstr ""
"Keď je povolené, pravítka sú predvolene viditeľné. Toto môže byť zmenené "
"pomocou príkazu „Zobraziť->Zobraziť bodové vzorky“."

# tooltip
#: app/config/gimprc-blurbs.h:499
msgid "Use GIMP in a single-window mode."
msgstr "Použije sa GIMP v režime jedného okna."

# tooltip
#: app/config/gimprc-blurbs.h:502
msgid "Hide docks and other windows, leaving only image windows."
msgstr "Skryje doky a ďalšie okná, ponechá iba okno obrázka."

# tooltip
#: app/config/gimprc-blurbs.h:505
msgid "Show the image tabs bar in single window mode."
msgstr "Zobraziť panel kariet obrázkov v režime jedného okna."

# tooltip
#: app/config/gimprc-blurbs.h:508
msgid "Enable the N-Point Deformation tool."
msgstr "Povoliť nástroj Deformácia pomocou N bodov."

# tooltip
#: app/config/gimprc-blurbs.h:511
msgid "Enable the Seamless Clone tool."
msgstr "Povoliť nástroj Bezšvové klonovanie."

#: app/config/gimprc-blurbs.h:514
msgid "Enable the Paint Select tool."
msgstr "Povoliť nástroj Výber maľovaním."

#: app/config/gimprc-blurbs.h:517
msgid "Use the new GtkListBox widget for simple lists."
msgstr "Použiť nový widget GtkListBox pre jednoduché zoznamy."

# tooltip
#: app/config/gimprc-blurbs.h:520
msgid "What to do when the space bar is pressed in the image window."
msgstr "Hovorí, čo sa má urobiť v okne s obrázkom pri stlačení medzerníka."

#: app/config/gimprc-blurbs.h:523
msgid "The compression method used for tile data stored in the swap file."
msgstr ""
"Metóda kompresie používaná pre dáta dlaždíc uložené v súbore medzipamäte."

# tooltip
#: app/config/gimprc-blurbs.h:526
msgid ""
"Sets the swap file location. GIMP uses a tile based memory allocation "
"scheme. The swap file is used to quickly and easily swap tiles out to disk "
"and back in. Be aware that the swap file can easily get very large if GIMP "
"is used with large images. Also, things can get horribly slow if the swap "
"file is created on a folder that is mounted over NFS.  For these reasons, it "
"may be desirable to put your swap file in \"/tmp\"."
msgstr ""
"Nastavuje umiestnenie odkladacieho swap súboru. GIMP používa schému alokácie "
"pamäte založenej na dlaždiciach. Odkladací súbor sa používa pre rýchle a "
"ľahké odkladanie dlaždíc na disk a späť do pamäte. Uvedomte si, že odkladací "
"priestor sa rýchlo môže stať veľmi veľkým, ak používate GIMP na veľké "
"obrázky. Taktiež, ak je odkladací súbor vytvorený v priečinku pripojenom cez "
"NFS, môže byť všetko strašne pomalé. Z týchto dôvodov môže byť vhodné "
"umiestniť váš odkladací súbor do „/tmp“."

# tooltip
#: app/config/gimprc-blurbs.h:535
msgid ""
"When enabled, you can change keyboard shortcuts for menu items by hitting a "
"key combination while the menu item is highlighted."
msgstr ""
"Keď je povolené, môžete meniť klávesové skratky položiek ponuky stlačením "
"kombinácie kláves, keď je položka v ponuke zvýraznená."

# tooltip
#: app/config/gimprc-blurbs.h:539
msgid "Save changed keyboard shortcuts when GIMP exits."
msgstr "Uloží zmenené klávesové skratky pri ukončení GIMPu."

# tooltip
#: app/config/gimprc-blurbs.h:542
msgid "Restore saved keyboard shortcuts on each GIMP startup."
msgstr "Obnoví uložené klávesové skratky pri každom spustení GIMPu."

# tooltip
#: app/config/gimprc-blurbs.h:545
msgid ""
"Sets the folder for temporary storage. Files will appear here during the "
"course of running GIMP.  Most files will disappear when GIMP exits, but some "
"files are likely to remain, so it is best if this folder not be one that is "
"shared by other users."
msgstr ""
"Nastavuje priečinok pre dočasné súbory. Počas behu programu GIMP sa tu budú "
"objavovať súbory. Väčšina súborov zmizne, keď GIMP skončí, ale niektoré "
"súbory pravdepodobne zostanú. Takže je dobré, keď tento priečinok nie je "
"zdieľaný s inými používateľmi."

#: app/config/gimprc-blurbs.h:551
msgid "The name of the theme to use."
msgstr "Názov motívu, ktorý sa má použiť."

# tooltip
#: app/config/gimprc-blurbs.h:554
msgid "Chooses the color scheme variant of the theme."
msgstr "Vyberá farebný variant témy."

# tooltip
#: app/config/gimprc-blurbs.h:560
msgid "The name of the icon theme to use."
msgstr "Názov témy ikon, ktorá sa má používať."

#: app/config/gimprc-blurbs.h:563
msgid "Override theme-set icon sizes."
msgstr "Prepísať veľkosti ikon nastavené motívom."

# tooltip
#: app/config/gimprc-blurbs.h:566
msgid "Use theme colors for preview"
msgstr "Použiť farby témy pre náhľad"

# tooltip
#: app/config/gimprc-blurbs.h:569
msgid "The size of the icons to use."
msgstr "Veľkosť ikon, ktoré sa majú používať."

# tooltip
#: app/config/gimprc-blurbs.h:572
msgid "When enabled, symbolic icons will be preferred if available."
msgstr ""
"Keď je povolené, symbolické ikony budú uprednostňované, ak sú dostupné."

#: app/config/gimprc-blurbs.h:578
msgid "Tweak font size of the graphical interface."
msgstr "Upraviť veľkosť písma grafického rozhrania."

#: app/config/gimprc-blurbs.h:581
msgid ""
"Sets the default rendering intent for the 'Convert to Color Profile' dialog."
msgstr ""
"Nastavuje predvolený zámer vykresľovania pre dialógové okno „Konvertovať do "
"farebného profilu“."

#: app/config/gimprc-blurbs.h:584
msgid ""
"Sets the default 'Black Point Compensation' state for the 'Convert to Color "
"Profile' dialog."
msgstr ""
"Nastavuje predvolený stav „Kompenzácia čierneho bodu“ pre dialógové okno "
"„Konvertovať do farebného profilu“."

#: app/config/gimprc-blurbs.h:588
msgid ""
"Sets the default layer dithering method for the 'Convert Precision' dialog."
msgstr ""
"Nastavuje predvolenú metódu rozptylu vrstiev pre dialógové okno „Konvertovať "
"presnosť“."

#: app/config/gimprc-blurbs.h:591
msgid ""
"Sets the default text layer dithering method for the 'Convert Precision' "
"dialog."
msgstr ""
"Nastavuje predvolenú metódu rozptylu textových vrstiev pre dialógové okno "
"„Konvertovať presnosť“."

#: app/config/gimprc-blurbs.h:594
msgid ""
"Sets the default channel dithering method for the 'Convert Precision' dialog."
msgstr ""
"Nastavuje predvolenú metódu rozptylu kanálov pre dialógové okno „Konvertovať "
"presnosť“."

#: app/config/gimprc-blurbs.h:597
msgid "Sets the default palette type for the 'Convert to Indexed' dialog."
msgstr ""
"Nastavuje predvolený typ palety pre dialógové okno „Konvertovať na "
"indexované“."

#: app/config/gimprc-blurbs.h:600
msgid ""
"Sets the default maximum number of colors for the 'Convert to Indexed' "
"dialog."
msgstr ""
"Nastavuje predvolený maximálny počet farieb pre dialógové okno „Konvertovať "
"na indexované“."

#: app/config/gimprc-blurbs.h:603
msgid ""
"Sets the default 'Remove duplicate colors' state for the 'Convert to "
"Indexed' dialog."
msgstr ""
"Nastavuje predvolený stav „Odstrániť zdvojené farby“ pre dialógové okno "
"„Konvertovať na indexované“."

#: app/config/gimprc-blurbs.h:606
msgid "Sets the default dithering type for the 'Convert to Indexed' dialog."
msgstr ""
"Nastavuje predvolený typ rozptylu pre dialógové okno „Konverzia na "
"indexované farby“."

#: app/config/gimprc-blurbs.h:609
msgid ""
"Sets the default 'Dither alpha' state for the 'Convert to Indexed' dialog."
msgstr ""
"Nastavuje predvolený stav „Rozptyl alfy“ pre dialógové okno „Konverzia na "
"indexované farby“."

#: app/config/gimprc-blurbs.h:612
msgid ""
"Sets the default 'Dither text layers' state for the 'Convert to Indexed' "
"dialog."
msgstr ""
"Nastavuje predvolený stav „Rozptyl textových vrstiev“ pre dialógové okno "
"„Konverzia na indexované farby“."

#: app/config/gimprc-blurbs.h:615
msgid "Sets the default fill type for the 'Canvas Size' dialog."
msgstr "Nastavuje predvolený typ výplne pre dialógové okno „Veľkosť plátna“."

#: app/config/gimprc-blurbs.h:618
msgid "Sets the default set of layers to resize for the 'Canvas Size' dialog."
msgstr ""
"Nastavuje predvolenú sadu vrstiev na zmenu veľkosti pre dialógové okno "
"„Veľkosť plátna“."

#: app/config/gimprc-blurbs.h:621
msgid ""
"Sets the default 'Resize text layers' state for the 'Canvas Size' dialog."
msgstr ""
"Nastavuje predvolený stav „Zmeniť veľkosť textových vrstiev“ pre dialógové "
"okno „Veľkosť plátna“."

#: app/config/gimprc-blurbs.h:624
msgid "Sets how items are searched and selected from a textual pattern."
msgstr ""
"Nastavuje, ako sa položky vyhľadávajú a vyberajú podľa textového vzoru."

#: app/config/gimprc-blurbs.h:627
msgid "Sets the default layer name for the 'New Layer' dialog."
msgstr "Nastavuje predvolený názov vrstvy pre dialógové okno „Nová vrstva“."

#: app/config/gimprc-blurbs.h:630
msgid "Sets the default mode for the 'New Layer' dialog."
msgstr "Nastavuje predvolený režim pre dialógové okno „Nová vrstva“."

# tooltip
#: app/config/gimprc-blurbs.h:633
msgid "Sets the default blend space for the 'New Layer' dialog."
msgstr ""
"Nastavuje predvolený priestor prelínania pre dialógové okno „Nová vrstva“."

# tooltip
#: app/config/gimprc-blurbs.h:636
msgid "Sets the default composite space for the 'New Layer' dialog."
msgstr ""
"Nastavuje predvolený priestor kompozície pre dialógové okno „Nová vrstva“."

# tooltip
#: app/config/gimprc-blurbs.h:639
msgid "Sets the default composite mode for the 'New Layer' dialog."
msgstr ""
"Nastavuje predvolený režim kompozície pre dialógové okno „Nová vrstva“."

#: app/config/gimprc-blurbs.h:642
msgid "Sets the default opacity for the 'New Layer' dialog."
msgstr "Nastavuje predvolené krytie pre dialógové okno „Nová vrstva“."

#: app/config/gimprc-blurbs.h:645
msgid "Sets the default fill type for the 'New Layer' dialog."
msgstr "Nastavuje predvolený typ výplne pre dialógové okno „Nová vrstva“."

#: app/config/gimprc-blurbs.h:648
msgid "Sets the default fill type for the 'Layer Boundary Size' dialog."
msgstr ""
"Nastavuje predvolený typ výplne pre dialógové okno „Veľkosť okraja vrstvy“."

#: app/config/gimprc-blurbs.h:651
msgid "Sets the default mask for the 'Add Layer Mask' dialog."
msgstr "Nastavuje predvolenú masku pre dialógové okno „Pridať masku vrstvy“."

#: app/config/gimprc-blurbs.h:654
msgid "Sets the default 'invert mask' state for the 'Add Layer Mask' dialog."
msgstr ""
"Nastavuje predvolený stav „invertovať masku“ pre dialógové okno „Pridať "
"masku vrstvy“."

# tooltip
#: app/config/gimprc-blurbs.h:657
msgid "Sets the default 'edit mask' state for the 'Add Layer Mask' dialog."
msgstr ""
"Nastavuje predvolený stav 'upraviť masku' pre dialógové okno 'Pridať masku "
"vrstvy'."

#: app/config/gimprc-blurbs.h:660
msgid "Sets the default merge type for the 'Merge Visible Layers' dialog."
msgstr ""
"Nastavuje predvolený typ zlúčenia pre dialógové okno „Zlúčiť viditeľné "
"vrstvy“."

#: app/config/gimprc-blurbs.h:663
msgid ""
"Sets the default 'Active group only' for the 'Merge Visible Layers' dialog."
msgstr ""
"Nastavuje predvolený stav „Len aktívna skupina“ pre dialógové okno „Zlúčiť "
"viditeľné vrstvy“."

#: app/config/gimprc-blurbs.h:666
msgid ""
"Sets the default 'Discard invisible' for the 'Merge Visible Layers' dialog."
msgstr ""
"Nastavuje predvolený stav „Zahodiť neviditeľné“ pre dialógové okno „Zlúčiť "
"viditeľné vrstvy“."

#: app/config/gimprc-blurbs.h:669
msgid "Sets the default channel name for the 'New Channel' dialog."
msgstr "Nastavuje predvolený názov kanálu pre dialógové okno „Nový kanál“."

#: app/config/gimprc-blurbs.h:672
msgid "Sets the default color and opacity for the 'New Channel' dialog."
msgstr "Nastavuje predvolenú farbu a krytie pre dialógové okno „Nový kanál“."

# tooltip
#: app/config/gimprc-blurbs.h:675
msgid "Sets the default path name for the 'New Path' dialog."
msgstr "Nastavuje predvolený názov cesty pre dialógové okno „Nová cesta“."

#: app/config/gimprc-blurbs.h:678
msgid "Sets the default folder path for the 'Export Path' dialog."
msgstr ""
"Nastavuje predvolenú cestu priečinka pre dialógové okno „Exportovať cestu“."

# tooltip
#: app/config/gimprc-blurbs.h:681
msgid ""
"Sets the default 'Export the selected paths' state for the 'Export Path' "
"dialog."
msgstr ""
"Nastavuje predvolený stav 'Exportovať vybrané cesty' pre dialógové okno "
"„Exportovať cestu“."

#: app/config/gimprc-blurbs.h:684
msgid "Sets the default folder path for the 'Import Path' dialog."
msgstr ""
"Nastavuje predvolenú cestu priečinka pre dialógové okno „Importovať cestu“."

#: app/config/gimprc-blurbs.h:687
msgid ""
"Sets the default 'Merge imported paths' state for the 'Import Path' dialog."
msgstr ""
"Nastavuje predvolený stav „Zlúčiť importované cesty“ pre dialógové okno "
"„Importovať cestu“."

#: app/config/gimprc-blurbs.h:690
msgid ""
"Sets the default 'Scale imported paths to fit size' state for the 'Import "
"Path' dialog."
msgstr ""
"Nastavuje predvolený stav „Škálovať importované cesty na veľkosť“ pre "
"dialógové okno „Importovať cestu“."

#: app/config/gimprc-blurbs.h:693
msgid "Sets the default feather radius for the 'Feather Selection' dialog."
msgstr ""
"Nastavuje predvolený polomer rozmazania pre dialógové okno „Zjemnenie "
"výberu“."

#: app/config/gimprc-blurbs.h:696
msgid ""
"Sets the default 'Selected areas continue outside the image' setting for the "
"'Feather Selection' dialog."
msgstr ""
"Nastavuje predvolené nastavenie „Vybrané oblasti pokračujú mimo obrázka“ pre "
"dialógové okno „Zjemnenie výberu“."

#: app/config/gimprc-blurbs.h:700
msgid "Sets the default grow radius for the 'Grow Selection' dialog."
msgstr ""
"Nastavuje predvolený polomer zväčšenia pre dialógové okno „Zväčšiť výber“."

#: app/config/gimprc-blurbs.h:703
msgid "Sets the default shrink radius for the 'Shrink Selection' dialog."
msgstr ""
"Nastavuje predvolený polomer zmenšenia pre dialógové okno „Zmenšiť výber“."

#: app/config/gimprc-blurbs.h:706
msgid ""
"Sets the default 'Selected areas continue outside the image' setting for the "
"'Shrink Selection' dialog."
msgstr ""
"Nastavuje predvolené nastavenie „Vybrané oblasti pokračujú mimo obrázka“ pre "
"dialógové okno „Zmenšiť výber“."

#: app/config/gimprc-blurbs.h:710
msgid "Sets the default border radius for the 'Border Selection' dialog."
msgstr "Nastavuje predvolený polomer okraja pre dialógové okno „Výber okraja“."

#: app/config/gimprc-blurbs.h:713
msgid ""
"Sets the default 'Selected areas continue outside the image' setting for the "
"'Border Selection' dialog."
msgstr ""
"Nastavuje predvolené nastavenie „Vybrané oblasti pokračujú mimo obrázka“ pre "
"dialógové okno „Výber okraja“."

#: app/config/gimprc-blurbs.h:717
msgid "Sets the default border style for the 'Border Selection' dialog."
msgstr "Nastavuje predvolený štýl okraja pre dialógové okno „Výber okraja“."

# tooltip
#: app/config/gimprc-blurbs.h:726
msgid "Sets the size of the thumbnail shown in the Open dialog."
msgstr "Nastavuje veľkosť miniatúry zobrazujúcej sa v dialógovom okne Otvoriť."

# tooltip
#: app/config/gimprc-blurbs.h:729
msgid ""
"The thumbnail in the Open dialog will be automatically updated if the file "
"being previewed is smaller than the size set here."
msgstr ""
"Miniatúra v dialógovom okne Otvoriť bude automaticky aktualizovaná, pokiaľ "
"je veľkosť miniatúry menšia ako je tu nastavená hodnota."

# tooltip
#: app/config/gimprc-blurbs.h:733
msgid ""
"When the amount of pixel data exceeds this limit, GIMP will start to swap "
"tiles to disk.  This is a lot slower but it makes it possible to work on "
"images that wouldn't fit into memory otherwise.  If you have a lot of RAM, "
"you may want to set this to a higher value."
msgstr ""
"Pokiaľ množstvo pixelových dát prekročí tento limit, GIMP začne dlaždice "
"ukladať do swapovacieho súboru.  To je oveľa pomalšie, ale umožní to "
"pracovať aj s obrázkami, ktoré sa nezmestia do pamäte. Ak máte veľa pamäte "
"RAM, môžete túto hodnotu zväčšiť."

# tooltip
#: app/config/gimprc-blurbs.h:739
msgid "Show the current foreground and background colors in the toolbox."
msgstr "Zobrazí vybranú farbu popredia a pozadia v okne so sadou nástrojov."

# tooltip
#: app/config/gimprc-blurbs.h:742
msgid "Show the currently selected brush, pattern and gradient in the toolbox."
msgstr "Zobrazí vybraný štetec, vzor a prechod v okne so sadou nástrojov."

#: app/config/gimprc-blurbs.h:745
msgid "Use a single toolbox button for grouped tools."
msgstr "Použiť jedno tlačidlo panelu nástrojov pre zoskupené nástroje."

# tooltip
#: app/config/gimprc-blurbs.h:748
msgid "Show the currently active image in the toolbox."
msgstr "Zobrazí aktívny obrázok v okne so sadou nástrojov."

# tooltip
#: app/config/gimprc-blurbs.h:751
msgid "Show the GIMP mascot at the top of the toolbox."
msgstr "Zobraziť maskota GIMPu v hornej časti panela nástrojov."

#: app/config/gimprc-blurbs.h:754
msgid ""
"The first color to use in the transparency checkerboard, when Transparency "
"Type is set to Custom colors."
msgstr ""
"Prvá farba pre šachovnicu priehľadnosti, keď je typ priehľadnosti nastavený "
"na vlastné farby."

#: app/config/gimprc-blurbs.h:758
msgid ""
"The second color to use in the transparency checkerboard, when Transparency "
"Type is set to Custom colors."
msgstr ""
"Druhá farba pre šachovnicu priehľadnosti, keď je typ priehľadnosti nastavený "
"na vlastné farby."

# tooltip
#: app/config/gimprc-blurbs.h:762
msgid "Sets the manner in which transparency is displayed in images."
msgstr "Nastavuje spôsob, akým sa v obrázkoch zobrazuje priehľadnosť."

# tooltip
#: app/config/gimprc-blurbs.h:765
msgid "Sets the size of the checkerboard used to display transparency."
msgstr ""
"Nastavuje veľkosť polí šachovnice, používaných pre zobrazenie priehľadnosti."

# tooltip
#: app/config/gimprc-blurbs.h:768
msgid ""
"When enabled, GIMP will not save an image if it has not been changed since "
"it was opened."
msgstr ""
"Keď je povolené, GIMP neuloží obrázok, pokiaľ nedôjde k jeho zmene od jeho "
"otvorenia."

#: app/config/gimprc-blurbs.h:772
msgid ""
"Sets the minimal number of operations that can be undone. More undo levels "
"are kept available until the undo-size limit is reached."
msgstr ""
"Nastavuje minimálny počet operácií, ktoré môžu byť vrátené spať. Viac "
"dostupných úrovní „kroku spať“ sa ukladá až pokiaľ nie je dosiahnutý tento "
"limit."

# tooltip
#: app/config/gimprc-blurbs.h:776
msgid ""
"Sets an upper limit to the memory that is used per image to keep operations "
"on the undo stack. Regardless of this setting, at least as many undo-levels "
"as configured can be undone."
msgstr ""
"Nastavuje horný limit pamäte, ktorá sa použije pre obrázok na udržanie "
"zásobníka vrátení. Bez ohľadu na toto nastavenie je možné vrátiť späť aspoň "
"toľko operácií ako je nastavené."

# tooltip
#: app/config/gimprc-blurbs.h:781
msgid "Sets the size of the previews in the Undo History."
msgstr "Nastavuje veľkosť náhľadov histórie pre vrátenie."

# tooltip
#: app/config/gimprc-blurbs.h:784
msgid "When enabled, pressing F1 will open the help browser."
msgstr "Keď je povolené, stlačením F1 sa spustí prehliadač pomocníka."

# tooltip
#: app/config/gimprc-blurbs.h:787
msgid "When enabled, uses OpenCL for some operations."
msgstr "Keď je povolené, použije sa OpenCL pre niektoré operácie."

#: app/config/gimprc-blurbs.h:798
msgid "There's a tradeoff between speed and quality of the zoomed-out display."
msgstr "Medzi rýchlosťou a kvalitou oddialenia zobrazenia existuje kompromis."

# label pri spinbuttone
#: app/config/gimprc-blurbs.h:805
msgid "The maximum number of actions saved in history."
msgstr "Maximálny počet akcií uložených v histórii."

