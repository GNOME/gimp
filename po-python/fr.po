#: plug-ins/python/palette-sort.py:90
msgid ""
"\n"
"    Format is 'start:nrows,length' . All items are optional.\n"
"\n"
"    The empty string selects all items, as does ':'\n"
"    ':4,' makes a 4-row selection out of all colors (length auto-"
"determined)\n"
"    ':4' also.\n"
"    ':1,4' selects the first 4 colors\n"
"    ':,4' selects rows of 4 colors (nrows auto-determined)\n"
"    ':3,4' selects 3 rows of 4 colors\n"
"    '4:' selects a single row of all colors after 4, inclusive.\n"
"    '3:,4' selects rows of 4 colors, starting at 3 (nrows auto-determined)\n"
"    '2:3,4' selects 3 rows of 4 colors (12 colors total), beginning at index "
"2.\n"
"    '4' is illegal (ambiguous)\n"
msgstr ""
"\n"
"    Le format est 'start:nrows,length' . Tous les éléments sont "
"facultatifs.\n"
"\n"
"    Une chaîne vide sélectionne tous les éléments, tout comme « : »\n"
"    « :4, » fait une sélection de 4 lignes de toutes les couleurs (longueur "
"auto-déterminée)\n"
"    « :4 » fait la même chose.\n"
"    « :1,4 » sélectionne les 4 premières couleurs\n"
"    « :,4 » sélectionne les lignes de 4 couleurs (nblignes auto-déterminé)\n"
"    « :3,4 » sélectionne 3 lignes de 4 couleurs\n"
"    « 4: » sélectionne une ligne de toutes les couleurs après 4, de manière "
"inclusive.\n"
"    « 3:,4 » sélectionne les lignes de 4 couleurs, en partant de de 3 "
"(nblignes auto-déterminé)\n"
"    « 2:3,4 » sélectionne 3 lignes de 4 couleurs (12 couleurs au total), en "
"partant de l’index 2.\n"
"    « 4 » est illégal (ambigu)\n"

